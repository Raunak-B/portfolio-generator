# =============================================================================
# Supabase (Project Settings → API)
# =============================================================================
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_or_publishable_key

# Server-only — never expose in client bundles
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# =============================================================================
# App
# =============================================================================
# Used for OAuth redirect URLs (local dev or production domain)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: GitHub App / OAuth app client ID (for reference; Supabase handles OAuth)
# Configure GitHub provider in Supabase Dashboard → Authentication → Providers → GitHub
GITHUB_CLIENT_ID=your_github_oauth_app_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_app_client_secret
