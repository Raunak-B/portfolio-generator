# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App (your Vercel URL — no trailing slash)
NEXT_PUBLIC_SITE_URL=https://portfolio-generator-blue.vercel.app

# Resume parser — FREE & UNLIMITED (default, works on Vercel, no API key)
RESUME_PARSER_PROVIDER=heuristic

# Optional paid/cloud AI (have rate limits or cost)
# RESUME_PARSER_PROVIDER=gemini
# GEMINI_API_KEY=your_gemini_api_key
# GEMINI_MODEL=gemini-2.0-flash
